{
  "name": "pinballzzz",
  "version": "0.1.0",
  "description": "Downwell aesthetics meet Jump King climbing pinball precision platformer",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"electron/**/*.ts\"",
    "test": "jest",
    "electron:dev": "tsc -p tsconfig.electron.json && concurrently -k \"npm run dev\" \"tsc -p tsconfig.electron.json -w\" \"electron .\"",
    "electron:build": "npm run build && tsc -p tsconfig.electron.json && electron .",
    "rapier-bump-check": "ts-node -O '{\"module\": \"commonjs\"}' tools/rapier-bump-check.ts",
    "replay-ci": "ts-node -O '{\"module\": \"commonjs\"}' tools/replay-runner/index.ts tests/replays"
  },
  "dependencies": {
    "@dimforge/rapier2d-compat": "^0.12.0",
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "concurrently": "^8.2.2",
    "electron": "^29.4.6",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  }
}
